# MIRA v0.x Environment Configuration
#
# ── External LLM calls — single consent switch ─────────────────────────
# MIRA makes NO external LLM calls (no learner text leaves your machine)
# unless this is set to "1". The switch gates BOTH Lane 2 feature
# extraction and Lane 3 candidate extraction. (The name is historical.)
# MIRA_ENABLE_LANE3=1
#
# ── Backend selection ──────────────────────────────────────────────────
# Default: auto-detect — Codex CLI > OpenAI > Anthropic > none.
# The Codex CLI backend uses a ChatGPT subscription (no API key needed).
# If both API keys are set, OpenAI is picked first; force Anthropic with
# MIRA_LLM_BACKEND=anthropic.
# MIRA_LLM_BACKEND=codex   # codex | openai | anthropic | none
# MIRA_LLM_MODEL=          # optional override (defaults: gpt-5.5 / gpt-5.4 / claude-sonnet-4-6)
#
# ── API keys (only for the corresponding backend) ──────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-api03-...
#
# ── Advanced: Lane 2 (Prolog) feature-extraction overrides ─────────────
# Uses the same auto-detect cascade as above when unset.
# MIRA_LLM_EXTRACT_BACKEND=
# MIRA_LLM_EXTRACT_MODEL=
#
# Disable Lane 2 entirely (Prolog verification off):
# MIRA_LANE2_ENABLED=false
